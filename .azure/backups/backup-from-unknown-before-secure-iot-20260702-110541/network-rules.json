{
  "backendNsgRules": [
    {
      "name": "Deny-Direct-Internet-Inbound",
      "properties": {
        "priority": 1000,
        "access": "Deny",
        "direction": "Inbound",
        "protocol": "*",
        "sourceAddressPrefix": "Internet",
        "sourcePortRange": "*",
        "destinationAddressPrefix": "*",
        "destinationPortRange": "*"
      }
    }
  ],
  "storageNsgRules": [
    {
      "name": "Allow-Backend-Only-Inbound",
      "properties": {
        "priority": 100,
        "access": "Allow",
        "direction": "Inbound",
        "protocol": "Tcp",
        "sourceAddressPrefix": "10.1.4.0/23",
        "sourcePortRange": "*",
        "destinationAddressPrefix": "10.1.2.0/24",
        "destinationPortRange": "443"
      }
    },
    {
      "name": "Deny-All-Other-Inbound-To-Storage",
      "properties": {
        "priority": 1000,
        "access": "Deny",
        "direction": "Inbound",
        "protocol": "*",
        "sourceAddressPrefix": "*",
        "sourcePortRange": "*",
        "destinationAddressPrefix": "*",
        "destinationPortRange": "*"
      }
    }
  ]
}
