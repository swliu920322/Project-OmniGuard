                              "name": "AZURE_STORAGE_ACCOUNT_KEY",
                              "value": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2023-01-01').keys[0].value]"
                            },
                            {
                              "name": "AZURE_OPENAI_ENDPOINT",
                              "value": "[format('https://{0}.openai.azure.com/', parameters('existingOpenAiName'))]"
                            },
                            {
                              "name": "LOCAL_MOCK_MODE",
                              "value": "false"
                            },
                            {
                              "name": "COSMOS_ENDPOINT",
                              "value": "[parameters('cosmosEndpoint')]"
                            },
                            {
                              "name": "COSMOS_KEY",
                              "value": "[parameters('cosmosKey')]"
                            }
                          ]
                        }
                      }
                    }
                  ],
                  "outputs": {
                    "functionAppName": {
                      "type": "string",
                      "value": "[format('{0}-brain-{1}', parameters('prefix'), uniqueString(resourceGroup().id))]"
                    }
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', format('{0}-mem-{1}', parameters('prefix'), uniqueString(resourceGroup().id)))]",
                "[resourceId('Microsoft.Storage/storageAccounts', format('{0}st{1}', parameters('prefix'), uniqueString(resourceGroup().id)))]",
                "[resourceId('Microsoft.Web/serverfarms', format('{0}-proto-plan', parameters('prefix')))]",
                "[resourceId('Microsoft.Network/virtualNetworks', parameters('spokeVNetName'))]"
              ]
            }
          ],
          "outputs": {
            "openAiName": {
              "type": "string",
              "value": "byo-decoupled-instance"
            },
            "iotHubConnectionString": {
              "type": "string",
              "value": "[format('HostName={0};SharedAccessKeyName=iothubowner;SharedAccessKey={1}', reference(resourceId('Microsoft.Devices/IotHubs', format('iot-{0}-{1}', parameters('prefix'), uniqueString(resourceGroup().id))), '2023-06-30').hostName, listKeys(resourceId('Microsoft.Devices/IotHubs', format('iot-{0}-{1}', parameters('prefix'), uniqueString(resourceGroup().id))), '2023-06-30').value[0].primaryKey)]"
            }
          }
        }
      },
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', variables('resourceGroupName'))]"
      ]
    }
  ]
}